# Copy to .env in this directory before running docker compose.

TZ=Asia/Shanghai
PUBLIC_HOST=localhost
CADDY_SITE_ADDRESS=http://localhost
BASIC_AUTH_USER=admin@example.com
# Generate with: caddy hash-password --plaintext 'your-password'
BASIC_AUTH_HASH=replace-with-caddy-hash
HTTP_PORT=80
HTTPS_PORT=443

POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant_dev_password
POSTGRES_PORT=5432

MONGO_INITDB_ROOT_USERNAME=assistant
MONGO_INITDB_ROOT_PASSWORD=assistant_dev_password
MONGO_DATABASE=assistant
MONGO_PORT=27017

PERSONAL_API_IMAGE=opensanxi-api:local
PERSONAL_API_PORT=8080
PERSONAL_WEB_IMAGE=opensanxi-web:local
PERSONAL_WEB_PORT=80
PERSONAL_MCP_IMAGE=opensanxi-mcp:local
PERSONAL_MCP_PORT=8787

LLM_BRIDGE_IMAGE=opensanxi-llm-bridge:local
LLM_BRIDGE_PORT=8765
LLM_BRIDGE_DEFAULT_MODEL=gpt-5.5
LLM_BRIDGE_REASONING_EFFORT=high
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=replace-me

HERMES_IMAGE=hermes-agent:local
HERMES_UID=10000
HERMES_GID=10000
HERMES_CONTEXT=../hermes
HERMES_UI_CONTEXT=../hermes-ui
HERMES_UI_PORT=3333
HERMES_UI_BASE_PATH=/agent
HERMES_UI_PASSWORD=
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8765
API_SERVER_KEY=change-me

LIBRECHAT_IMAGE=registry.librechat.ai/danny-avila/librechat-dev:latest
LIBRECHAT_RAG_IMAGE=registry.librechat.ai/danny-avila/librechat-rag-api-dev-lite:latest
LIBRECHAT_PORT=3080
LIBRECHAT_DOMAIN_CLIENT=http://localhost:8088/chat/
LIBRECHAT_DOMAIN_SERVER=http://localhost:8088/chat/
LIBRECHAT_ALLOW_EMAIL_LOGIN=true
LIBRECHAT_ALLOW_REGISTRATION=true
LIBRECHAT_ALLOW_UNVERIFIED_EMAIL_LOGIN=true
LIBRECHAT_MONGO_DATABASE=LibreChat
MEILI_MASTER_KEY=change-me-meili-master-key

PERSONAL_API_KEY=change-me-personal-api-key
