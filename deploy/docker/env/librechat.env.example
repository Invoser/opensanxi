HOST=0.0.0.0
PORT=3080
CONFIG_PATH=/app/librechat.yaml

MONGO_URI=mongodb://assistant:assistant_dev_password@mongo:27017/LibreChat?authSource=admin
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-meili-master-key

RAG_API_URL=http://librechat-rag:8000
RAG_PORT=8000

ENDPOINTS=custom
PERSONAL_API_KEY=change-me-personal-api-key
API_SERVER_KEY=change-me
DOMAIN_CLIENT=http://localhost:8088/chat/
DOMAIN_SERVER=http://localhost:8088/chat/
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
CREDS_KEY=change-me-32-byte-creds-key
CREDS_IV=change-me-16-byte-iv
