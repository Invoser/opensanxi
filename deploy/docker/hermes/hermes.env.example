HERMES_UID=10000
HERMES_GID=10000

API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8765
API_SERVER_KEY=change-me

POSTGRES_URL=postgresql://assistant:assistant_dev_password@postgres:5432/assistant
MONGO_URI=mongodb://assistant:assistant_dev_password@mongo:27017/assistant?authSource=admin

PERSONAL_API_URL=http://personal-api:8080
PERSONAL_MCP_URL=http://personal-mcp:8787
LIBRECHAT_URL=http://librechat:3080

# Set at least one model/provider key for real agent use.
# For this project, provider secrets can be mounted into /opt/data/.env.
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# For sub.sanxi.cfd, Hermes' host-derived fallback looks for CFD_API_KEY.
# Keep these aliases equal when using the Sanxi/Baixian-compatible gateway.
# BAIXIAN_BASE_URL=https://sub.sanxi.cfd/v1
# BAIXIAN_API_KEY=
# CFD_API_KEY=
# SANXI_API_KEY=
# CUSTOM_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
