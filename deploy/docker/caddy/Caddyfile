{
	admin {$CADDY_ADMIN}
}

{$CADDY_SITE_ADDRESS:http://localhost} {
	encode zstd gzip
	@protected not path /chat/* /favicon.ico /manifest.webmanifest /robots.txt /.well-known/*
	basic_auth @protected {
		{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
	}

	@chatWithBasicAuth {
		path /chat/*
		header Authorization "Basic *"
	}
	handle @chatWithBasicAuth {
		uri strip_prefix /chat
		request_header -Authorization
		reverse_proxy librechat:{$LIBRECHAT_PORT:3080}
	}

	handle_path /api/* {
		reverse_proxy personal-api:{$PERSONAL_API_PORT:8080} {
			header_up -Authorization
		}
	}

	handle_path /mcp/* {
		reverse_proxy personal-mcp:{$PERSONAL_MCP_PORT:8787} {
			header_up -Authorization
		}
	}

	handle_path /hermes/* {
		reverse_proxy hermes:{$API_SERVER_PORT:8765} {
			header_up -Authorization
		}
	}

	handle_path /llm/* {
		reverse_proxy llm-bridge:{$LLM_BRIDGE_PORT:8765} {
			header_up -Authorization
		}
	}

	handle_path /chat/* {
		reverse_proxy librechat:{$LIBRECHAT_PORT:3080}
	}

	handle {
		reverse_proxy personal-web:{$PERSONAL_WEB_PORT:80} {
			header_up -Authorization
		}
	}
}
